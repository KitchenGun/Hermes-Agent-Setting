HERMES_MODE=opencode
HERMES_BRIDGE_URL=http://127.0.0.1:8765/api/discord/execute
HERMES_MAX_WORKERS=4
HERMES_BASE_PORT=4096
HERMES_SKILL_DIR=skills
HERMES_AGENT_DIR=agents
HERMES_TASK_TIMEOUT=120
HERMES_MAX_RETRIES=2
HERMES_REGISTRY_HOT_RELOAD=true

# Google Calendar integration example
# GOOGLE_CALENDAR_ACCESS_TOKEN=ya29...
# or refresh-token flow:
# GOOGLE_CALENDAR_REFRESH_TOKEN=...
# GOOGLE_CALENDAR_CLIENT_ID=...
# GOOGLE_CALENDAR_CLIENT_SECRET=...

# Discord bot example
# DISCORD_BOT_TOKEN=your_discord_bot_token_here

# command mode example
# HERMES_MODE=command
# HERMES_START_COMMAND=python E:\path\to\hermes.py --start
# HERMES_STATUS_COMMAND=python E:\path\to\hermes.py --status
# HERMES_STOP_COMMAND=python E:\path\to\hermes.py --stop
# HERMES_SEND_COMMAND=python E:\path\to\hermes.py --prompt

# http mode example
# HERMES_MODE=http
# HERMES_HTTP_BASE_URL=http://127.0.0.1:8787
# HERMES_HTTP_TOKEN=
